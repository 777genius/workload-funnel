{
  "name": "workload-funnel",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@10.33.4",
  "engines": {
    "node": ">=24.0.0 <25"
  },
  "scripts": {
    "architecture:check": "node tooling/architecture/check-dependencies.mjs && node tooling/architecture/check-mutation-fence-import-bijection.mjs && node tooling/architecture/generate-composition.mjs --check && node tooling/architecture/check-phase7-hyperqueue.mjs && node tooling/architecture/check-phase8-production.mjs",
    "build": "pnpm --filter './packages/*' --filter './apps/operator-cli' --filter './apps/scheduler-mutation-gateway' build",
    "canary:hosted": "pnpm build && node tooling/hosted-canary/run.mjs",
    "changeset": "changeset",
    "changeset:status": "changeset status --since=main",
    "check": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test && pnpm architecture:check && pnpm exports:check",
    "exports:check": "node tooling/architecture/check-package-exports.mjs",
    "feasibility:run": "node tooling/phase-0-5/run.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "generate": "node tooling/architecture/generate-composition.mjs",
    "lint": "pnpm lint:code && pnpm lint:docs",
    "lint:code": "eslint . --max-warnings=0",
    "lint:docs": "markdownlint-cli2 \"**/*.md\" \"#node_modules\" \"#.pnpm-store\"",
    "test": "vitest run",
    "test:e2e": "vitest run tooling/e2e/full-synthetic-lifecycle.test.ts",
    "test:hosted-canary": "vitest run packages/bridge-subscription-runtime/src/features/runtime-operation-dispatch/tests/hosted-canary-runtime.test.ts tooling/hosted-canary/hosted-canary.test.mjs && node --test tooling/hosted-canary/standalone-probe.process-regression.mjs",
    "test:phase8": "vitest run --testNamePattern=\"Phase 8|Phase 4D\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@workload-funnel/bridge-subscription-runtime": "workspace:*",
    "@workload-funnel/kernel": "workspace:*"
  },
  "devDependencies": {
    "@changesets/cli": "2.29.8",
    "@eslint/js": "9.39.4",
    "@types/node": "24.13.3",
    "eslint": "9.39.4",
    "markdownlint-cli2": "0.19.0",
    "prettier": "3.8.1",
    "typescript": "5.9.3",
    "typescript-eslint": "8.54.0",
    "vitest": "4.1.10"
  }
}
