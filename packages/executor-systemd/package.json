{
  "name": "@workload-funnel/executor-systemd",
  "version": "0.1.0",
  "private": true,
  "description": "Fail-closed systemd transient-unit adapter contracts",
  "license": "MIT",
  "type": "module",
  "dependencies": {
    "@workload-funnel/kernel": "workspace:*",
    "@workload-funnel/node-execution": "workspace:*"
  },
  "exports": {
    "./capability-discovery": {
      "types": "./dist/features/capability-discovery/index.d.ts",
      "import": "./dist/features/capability-discovery/index.js"
    },
    "./cgroup-resource-mapping": {
      "types": "./dist/features/cgroup-resource-mapping/index.d.ts",
      "import": "./dist/features/cgroup-resource-mapping/index.js"
    },
    "./journal-result-collection": {
      "types": "./dist/features/journal-result-collection/index.d.ts",
      "import": "./dist/features/journal-result-collection/index.js"
    },
    "./transient-unit-cancellation": {
      "types": "./dist/features/transient-unit-cancellation/index.d.ts",
      "import": "./dist/features/transient-unit-cancellation/index.js"
    },
    "./transient-unit-observation": {
      "types": "./dist/features/transient-unit-observation/index.d.ts",
      "import": "./dist/features/transient-unit-observation/index.js"
    },
    "./transient-unit-start": {
      "types": "./dist/features/transient-unit-start/index.d.ts",
      "import": "./dist/features/transient-unit-start/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node ../../tooling/build-linux-project-quota-helper.mjs"
  }
}
