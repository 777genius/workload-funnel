    },
    "./redaction-policy": {
      "types": "./dist/features/redaction-policy/index.d.ts",
      "import": "./dist/features/redaction-policy/index.js"
    },
    "./telemetry-export": {
      "types": "./dist/features/telemetry-export/index.d.ts",
      "import": "./dist/features/telemetry-export/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json"
  }
