{
  "name": "@workload-funnel/observability",
  "version": "0.1.0",
  "private": true,
  "description": "Structured telemetry, audit export, and redaction adapters for WorkloadFunnel",
  "license": "MIT",
  "type": "module",
  "dependencies": {
    "@workload-funnel/workload-control": "workspace:*"
  },
  "exports": {
    "./audit-export": {
      "types": "./dist/features/audit-export/index.d.ts",
