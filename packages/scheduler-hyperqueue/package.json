    },
    "./hyperqueue-cli-mutation": {
      "types": "./dist/features/hyperqueue-cli-mutation/index.d.ts",
      "import": "./dist/features/hyperqueue-cli-mutation/index.js"
    },
    "./hyperqueue-reconciliation": {
      "types": "./dist/features/hyperqueue-reconciliation/index.d.ts",
