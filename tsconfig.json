{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "noEmit": true,
    "paths": {
      "@workload-funnel/artifact-store-filesystem/*": [
        "packages/artifact-store-filesystem/src/features/*/index.ts"
      ],
      "@workload-funnel/artifact-store-object/*": [
        "packages/artifact-store-object/src/features/*/index.ts"
      ],
      "@workload-funnel/control-service/*": [
        "apps/control-service/src/features/*/index.ts"
      ],
      "@workload-funnel/dispatcher-local/*": [
        "packages/dispatcher-local/src/features/*/index.ts"
      ],
      "@workload-funnel/executor-systemd/*": [
        "packages/executor-systemd/src/features/*/index.ts"
      ],
      "@workload-funnel/kernel": ["packages/kernel/src/index.ts"],
      "@workload-funnel/node-execution/*": [
        "packages/node-execution/src/features/*/index.ts"
      ],
      "@workload-funnel/node-agent/*": [
        "apps/node-agent/src/features/*/index.ts"
      ],
      "@workload-funnel/node-launcher/*": [
        "apps/node-launcher/src/features/*/index.ts"
      ],
      "@workload-funnel/result-sealer/*": [
        "apps/result-sealer/src/features/*/index.ts"
      ],
      "@workload-funnel/store-postgres/*": [
        "packages/store-postgres/src/features/*/index.ts"
      ],
      "@workload-funnel/store-sqlite/*": [
        "packages/store-sqlite/src/features/*/index.ts"
      ],
      "@workload-funnel/workload-control/*": [
        "packages/workload-control/src/features/*/index.ts"
      ]
    },
    "types": ["node"]
  },
  "exclude": ["**/dist/**", "**/node_modules/**", ".pnpm-store", ".tmp"],
  "include": ["apps/**/*.ts", "packages/**/*.ts", "vitest.config.ts"]
}
